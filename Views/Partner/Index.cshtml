@model IEnumerable<InsurancePartnerManagement.Models.Partner>

@{
    ViewData["Title"] = "Lista partnera";
}

<div class="container mt-4">
    @Html.AntiForgeryToken()

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Lista partnera</h2>
        <a href="/Partner/Create" class="btn btn-primary">Novi partner</a>
    </div>

    <table class="table table-hover">
        <thead class="thead-dark">
            <tr>
                <th>Ime i prezime</th>
                <th>Broj partnera</th>
                <th>OIB</th>
                <th>Tip</th>
                <th>Stranac</th>
                <th>Spol</th>
                <th>Datum unosa</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var partner in Model)
            {
                <tr data-id="@partner.Id"
                    style="cursor:pointer"
                    class="partner-row @(ViewBag.NewPartnerId == partner.Id ? "table-success" : "")">
                    <td style="max-width: 200px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">@partner.FirstName @partner.LastName</td>
                    <td>@partner.PartnerNumber</td>
                    <td>@(partner.CroatianPIN ?? "-")</td>
                    <td>@(partner.PartnerTypeId == 1 ? "Personal" : "Legal")</td>
                    <td>@(partner.IsForeign ? "Da" : "Ne")</td>
                    <td>@partner.Gender</td>
                    <td>@partner.CreatedAtUtc.ToString("dd.MM.yyyy HH:mm")</td>
                </tr>
            }
        </tbody>
    </table>

    <div class="modal" id="partnerModal" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Detalji partnera</h5>
                    <button type="button" class="close" data-dismiss="modal">
                        <span>&times;</span>
                    </button>
                </div>
                <div class="modal-body" id="modalBody">
                </div>
            </div>
        </div>
    </div>

    <div class="modal" id="policyModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Unos police</h5>
                    <button type="button" class="close" data-dismiss="modal">
                        <span>&times;</span>
                    </button>
                </div>
                <div class="modal-body">
                    <form id="policyForm">
                        <input type="hidden" id="policyPartnerId" />
                        <div class="form-group">
                            <label>Broj police (10-15 znakova)</label>
                            <input type="text" id="policyNumber" class="form-control" />
                            <span id="policyNumberError" class="text-danger"></span>
                        </div>
                        <div class="form-group">
                            <label>Iznos police</label>
                            <input type="number" id="policyAmount" class="form-control" step="0.01" />
                            <span id="policyAmountError" class="text-danger"></span>
                        </div>
                        <button type="button" class="btn btn-primary" id="savePolicyBtn">Spremi policu</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $.ajaxSetup({
            headers: {
                'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
            }
        });

        $(document).ready(function () {
            var currentPartnerId = null;

            function checkAndMarkPartner(partnerId, nameCell) {
                $.get('/Partner/GetPolicyStats?partnerId=' + partnerId, function (stats) {
                    if (stats.count > 5 || stats.totalAmount > 5000) {
                        var current = nameCell.text();
                        if (!current.startsWith('* ')) {
                            nameCell.text('* ' + current);
                        }
                    }
                });
            }

            $('.partner-row').each(function () {
                var partnerId = $(this).data('id');
                var nameCell = $(this).find('td:first');
                checkAndMarkPartner(partnerId, nameCell);
            });

            function showPartnerModal(partnerId) {
                $.get('/Partner/Details/' + partnerId, function (data) {
                    var partner = data.partner;
                    var policies = data.policies;

                    var html = `
                        <table class="table table-sm" style="border-top: none;">
                            <tr style="border-top: none;"><th style="border-top: none; width: 140px;">Ime i prezime</th><td style="border-top: none; word-break: break-all;">${partner.firstName} ${partner.lastName}</td></tr>
                            <tr><th>Adresa</th><td style="word-break: break-all;">${partner.address ?? '-'}</td></tr>
                            <tr><th>Broj partnera</th><td style="word-break: break-all;">${partner.partnerNumber}</td></tr>
                            <tr><th>OIB</th><td>${partner.croatianPIN ?? '-'}</td></tr>
                            <tr><th>Tip</th><td>${partner.partnerTypeId === 1 ? 'Personal' : 'Legal'}</td></tr>
                            <tr><th>Datum unosa</th><td>${new Date(partner.createdAtUtc).toLocaleString('hr-HR')}</td></tr>
                            <tr><th>Unio korisnik</th><td>${partner.createdByUser}</td></tr>
                            <tr><th>Stranac</th><td>${partner.isForeign ? 'Da' : 'Ne'}</td></tr>
                            <tr><th>External Code</th><td>${partner.externalCode ?? '-'}</td></tr>
                            <tr><th>Spol</th><td>${partner.gender}</td></tr>
                        </table>
                        <hr>
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <h5>Police</h5>
                            <button type="button" class="btn btn-primary btn-sm" id="addPolicyBtn" data-partner-id="${partner.id}">Dodaj policu</button>
                        </div>
                        ${policies.length === 0 ? '<p class="text-muted">Nema unesenih polica</p>' : `
                        <table class="table table-sm">
                            <thead><tr><th>Broj police</th><th>Iznos</th></tr></thead>
                            <tbody>
                                ${policies.map(p => `<tr><td>${p.policyNumber}</td><td>${p.amount.toLocaleString('hr-HR', { minimumFractionDigits: 2, maximumFractionDigits: 2 })} €</td></tr>`).join('')}
                            </tbody>
                        </table>`}
                    `;

                    $('#modalBody').html(html);
                    $('#partnerModal').modal('show');
                });
            }

            $('.partner-row').click(function () {
                var id = $(this).data('id');
                showPartnerModal(id);
            });

            $('#policyModal').on('hidden.bs.modal', function () {
                if (currentPartnerId) {
                    showPartnerModal(currentPartnerId);
                }
            });

            $(document).on('click', '#addPolicyBtn', function () {
                var partnerId = $(this).data('partner-id');
                currentPartnerId = partnerId;
                $('#policyPartnerId').val(partnerId);
                $('#partnerModal').modal('hide');
                $('#policyModal').modal('show');
            });

            $('#savePolicyBtn').click(function () {
                var policyNumber = $('#policyNumber').val();
                var amount = $('#policyAmount').val();
                var partnerId = $('#policyPartnerId').val();

                var valid = true;

                if (policyNumber.length < 10 || policyNumber.length > 15) {
                    $('#policyNumberError').text('Broj police mora imati između 10 i 15 znakova');
                    valid = false;
                } else {
                    $('#policyNumberError').text('');
                }

                if (!amount || amount <= 0) {
                    $('#policyAmountError').text('Iznos mora biti veći od 0');
                    valid = false;
                } else {
                    $('#policyAmountError').text('');
                }

                if (!valid) return;

                $.post('/Partner/CreatePolicy', {
                    PolicyNumber: policyNumber,
                    Amount: amount,
                    PartnerId: partnerId
                })
                .done(function () {
                    $('#policyModal').modal('hide');
                    $('#policyNumber').val('');
                    $('#policyAmount').val('');

                    var row = $('.partner-row[data-id="' + partnerId + '"]');
                    var nameCell = row.find('td:first');
                    checkAndMarkPartner(partnerId, nameCell);
                })
                .fail(function () {
                    alert('Greška pri spremanju police');
                });
            });
        });
    </script>
}